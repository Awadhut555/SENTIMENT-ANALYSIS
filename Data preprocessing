stop_words = set(stopwords.words('english'))

def clean_text(text):
    text = text.lower()                          # Lowercase
    text = re.sub(r'[^a-zA-Z]', ' ', text)       # Remove symbols
    words = text.split()
    words = [word for word in words if word not in stop_words]
    return " ".join(words)

